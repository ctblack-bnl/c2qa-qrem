# Copy this file to .env and fill in your actual values.
# .env is gitignored and will never be committed.

PROVIDER=claude

# Azure Claude (Anthropic) — primary provider
AZURE_CLAUDE_BASE_URL=https://your-endpoint.services.ai.azure.com/anthropic
AZURE_CLAUDE_API_KEY=your-key-here
AZURE_CLAUDE_DEPLOYMENT=claude-sonnet-4-6

# Azure OpenAI (GPT) — fallback provider
AZURE_BASE_URL=https://your-endpoint.openai.azure.com/openai/v1/
AZURE_OPENAI_API_KEY=your-key-here